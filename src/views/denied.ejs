<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wakenerr - Access Denied</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="app-header">
    <div class="header-left">
      <h1 class="app-title">Wakenerr</h1>
    </div>
  </header>
  <main class="content">
    <div class="denied-card">
      <h2>Access Denied</h2>
      <p>Your account is not authorized to use Wakenerr.</p>
      <p>Contact the administrator to request access.</p>
      <a href="/auth/logout" class="btn btn-small">Sign out</a>
    </div>
  </main>
</body>
</html>
